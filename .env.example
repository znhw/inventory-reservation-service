# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=development        # development | production | test

# Redis
REDIS_URL=redis://localhost:6379
# Production example: redis://:yourpassword@your-redis-host:6379
# With TLS:          rediss://your-redis-host:6380

# Queue
QUEUE_CONCURRENCY=5         # workers processing jobs in parallel per queue

# Logging
LOG_LEVEL=info              # fatal | error | warn | info | debug | trace